{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-terra",
  "share": "disabled",
  "autoupdate": true,
  "lsp": true,
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "x": {
      "type": "remote",
      "url": "https://api.x.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:X_BEARER_TOKEN}"
      }
    },
    "x-docs": {
      "type": "remote",
      "url": "https://docs.x.com/mcp",
      "enabled": true
    }
  }
}
