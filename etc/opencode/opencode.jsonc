{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.7-code",
  "share": "disabled",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "x": {
      "type": "remote",
      "url": "https://api.x.com/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:X_BEARER_TOKEN}"
      }
    },
    "x-docs": {
      "type": "remote",
      "url": "https://docs.x.com/mcp",
      "enabled": true
    }
  }
}
